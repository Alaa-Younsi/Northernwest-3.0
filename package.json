{
  "name": "northernwest",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "bun --watch server/index.ts",
    "dev:full": "concurrently \"vite\" \"bun --watch server/index.ts\" --names \"vite,server\" --prefix-colors \"cyan,red\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "server:dev": "bun --watch server/index.ts",
    "server:build": "tsc -p tsconfig.server.json"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.6.0",
    "@react-three/drei": "^9",
    "@react-three/fiber": "^8",
    "@supabase/supabase-js": "^2.43.4",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "framer-motion": "^11.2.10",
    "helmet": "^7.1.0",
    "i18next": "^23.11.5",
    "i18next-browser-languagedetector": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.4",
    "react-hook-form": "^7.52.0",
    "react-i18next": "^14.1.2",
    "react-router-dom": "^6.23.1",
    "three": "^0.169",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169",
    "@vercel/node": "^5.7.13",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  }
}
